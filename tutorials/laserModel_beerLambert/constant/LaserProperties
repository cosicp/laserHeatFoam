FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      LaserProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

timeVsLaserPosition
{
    file        "$FOAM_CASE/constant/timeVsLaserPosition";
    outOfBounds clamp;
}

timeVsLaserPower
{
    file        "$FOAM_CASE/constant/timeVsLaserPower";
    outOfBounds clamp;
}

laserModel            beerLambert;
laserRadius           50e-6;
absorptivity          0.50;
absorptionCoefficient 28000;
substrateProbeDepth   50e-6;

