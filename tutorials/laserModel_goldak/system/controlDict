FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
libs
(
    "libpbfRadEvapTemperature.dylib"
);

application     laserHeatFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         700e-6;

deltaT          2e-7;

writeControl    runTime;

writeInterval   100e-6;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

adjustTimeStep  yes;

maxDeltaT       1e-6;     // whatever upper bound you allow
maxDi           0.5;      // typical 0.1–1.0 (smaller = more conservative)
// ************************************************************************* //
