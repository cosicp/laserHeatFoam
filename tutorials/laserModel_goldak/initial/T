FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    leftWall
    {
      type		zeroGradient;
    }
    rightWall
    {
      type		zeroGradient;
    }

    topWall
    {
        // Radiation + evaporation heat loss (Proell et al. 2023, eqs. 11-12)
        type            pbfRadEvapTemperature;

        // Thermal conductivity field name (must match createFields.H)
        kappa           k;
        // Enable/disable evaporation term
        enableEvap      true;
        value           uniform 300;
    }

    bottomWall
    {
        type fixedValue;
        value uniform 300;
    }

    front
    {
	type		zeroGradient;
    }
    back
    {
      type		zeroGradient;
    }
    solidInterface
    {
      type		zeroGradient;
    }
}


