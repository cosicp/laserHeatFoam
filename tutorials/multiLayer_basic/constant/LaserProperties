FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      LaserProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

timeVsLaserPosition
{
    file        "$FOAM_CASE/constant/timeVsLaserPosition";
    outOfBounds clamp;
}

timeVsLaserPower
{
    file        "$FOAM_CASE/constant/timeVsLaserPower";
    outOfBounds clamp;
}

laserModel          cylindrical;
laserRadius         50e-6;
absorptivity        0.5;
absorptionDepth     30e-6;


