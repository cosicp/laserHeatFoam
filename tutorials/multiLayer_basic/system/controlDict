FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     laserHeatFoam;

startFrom       startTime;

startTime       0;

// endTime is overridden per-layer by the solver. The value here is
// only relevant if the multi-layer dictionary is missing.
stopAt          endTime;

endTime         800e-6;

deltaT          1e-6;

writeControl    runTime;

writeInterval   10e-6;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

adjustTimeStep  yes;

maxDeltaT       2e-6;
maxDi           0.5;


// ************************************************************************* //
