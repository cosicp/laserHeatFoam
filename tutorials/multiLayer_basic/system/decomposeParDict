FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      decomposeParDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

numberOfSubdomains 4;

// Decompose along y (the laser scan direction). Each rank holds a
// 10 x 10 x 36 chunk; every layer crosses all four ranks, which
// stresses the parallel BFS in multiLayer.H and the processor-patch
// path in fvMeshSubset / dynamicRefineFvMesh.
method          simple;

simpleCoeffs
{
    n           (1 4 1);
}

