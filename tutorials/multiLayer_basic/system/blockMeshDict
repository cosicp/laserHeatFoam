FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convertToMeters 1.0;

// 4 layers x 30um thickness in z, 200um x 800um in plan view.
// Cell count: 10 x 40 x 4 = 1600 (400 per layer; one cell-row per layer
// so face-neighbour growth from baseplate maps 1:1 onto layers).

vertices
(
    (0       0       0)        // 0
    (200e-6  0       0)        // 1
    (200e-6  800e-6  0)        // 2
    (0       800e-6  0)        // 3
    (0       0       120e-6)   // 4
    (200e-6  0       120e-6)   // 5
    (200e-6  800e-6  120e-6)   // 6
    (0       800e-6  120e-6)   // 7
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (10 40 4) simpleGrading (1 1 1)
);

edges
(
);

boundary
(
    baseplate
    {
        type wall;
        faces
        (
            (0 3 2 1)
        );
    }
    top
    {
        type patch;
        faces
        (
            (4 5 6 7)
        );
    }
    front
    {
        type patch;
        faces
        (
            (1 2 6 5)
        );
    }
    back
    {
        type patch;
        faces
        (
            (0 4 7 3)
        );
    }
    leftWall
    {
        type patch;
        faces
        (
            (1 5 4 0)
        );
    }
    rightWall
    {
        type patch;
        faces
        (
            (3 7 6 2)
        );
    }
);

mergePatchPairs
(
);


