FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Density [kg/m^3]
rho             4100;

// Specific heat [J/kg/K]
Cp              570;

// Phase-dependent thermal conductivity [W/m/K]
// kp: powder  (low - highly porous)
// ks: solid   (Ti-6Al-4V bulk)
// km: melt    (liquid Ti, higher than solid)
kp              0.2;
ks              6.7;
km              30.0;

// Melting temperature [K]
Tm              Tm [0 0 0 1 0 0 0] 1878;

// Temperature interval for latent heat smoothing [K]
dT              100;

// Optional: reference temperature
TRef            TRef [0 0 0 1 0 0 0] 300;
Tinf            Tinf [0 0 0 1 0 0 0] 300;

Tl             1928;
Ts             1878;

// Latent heat for melting [J/kg]
L               2.85e5;

// Optional: make properties temperature-dependent (example)
// Cp = table
// kappa = table
// But for now keep constant

// ************************************************************************* //