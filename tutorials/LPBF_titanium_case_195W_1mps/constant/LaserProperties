FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      PhaseFieldProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

timeVsLaserPosition
{
    file    "$FOAM_CASE/constant/timeVsLaserPosition";
    outOfBounds clamp;
}

timeVsLaserPower
{
    file    "$FOAM_CASE/constant/timeVsLaserPower";
    outOfBounds clamp;
}

// TODO - add an option to change laser direction (currently fixed in code)
// Laser angle (normalised in the code)
/* V_incident (0 1 0); */

// Q[cellI] = (2.0 * A * laserPower) / (M_PI * Foam::sqr(rb) * d) 
//                     * Foam::exp(-2.0 * Foam::sqr(r) / Foam::sqr(rb)) 
//                     * Foam::exp(-(z_layer - cellPos.z()) / d);

laserRadius 50e-6;   // rb
absorptivity 0.5;      // A
absorptionDepth 30e-6; // d

laserModel exponential;

// If you have (or can get) single-track cross-sections (melt pool width/depth) for your material + machine settings:
// Fix rb from your beam characterization.
// Choose A from literature / prior calibration.
// Sweep d until your simulated melt pool depth matches experiment (and width as best as possible).
// This is the most reliable because LPBF “effective depth” is inherently empirical.

// If your melt pool is too shallow (but width looks okay): increase d a bit.
// If it’s too deep / too diffused: decrease d.
// If both width and depth are off: you may need to revisit A, rb, and/or use a different source model (e.g., Goldak / double-ellipsoid) because your current model ties width strongly to rb.
